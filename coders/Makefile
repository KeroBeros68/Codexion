# **************************************************************************** #
#                                  VARIABLES                                   #
# **************************************************************************** #

# Output Name
NAME = codexion

# Directories
OBJ_DIR = Obj

COD = \
		main.c \
		init.c \
		mem.c \
		logs.c \
		sim.c \
		clean.c \
		error.c \
		utils.c \
		parsing.c

SRCS =	$(COD)

INCLUDES = \
			coders.h

# Compilation
CC = cc
CFLAGS = -Wall -Werror -Wextra -pthread -I.

# Object name
OBJS = $(addprefix $(OBJ_DIR)/, $(SRCS:.c=.o))

#
TOTAL := $(words $(OBJS))
CURRENT := 0

# **************************************************************************** #
#									Rules									   #
# **************************************************************************** #

all: $(NAME)

$(NAME): $(OBJS)
	printf "$(CYAN)CrГ©ation du programme $(NAME)...$(RESET) "
	if $(CC) $(CFLAGS) -o $@ $(OBJS) 2>/dev/null; then \
		echo "$(GREEN)вң“$(RESET)"; \
	else \
		echo "$(RED)вң—$(RESET)"; \
		$(CC) $(CFLAGS) -o $@ $(OBJS); \
	fi

$(OBJ_DIR)/%.o: %.c $(INCLUDES) | $(OBJ_DIR)
	$(eval CURRENT=$(shell echo $$(($(CURRENT)+1))))
	printf "$(CYAN)[%2d/%2d]$(RESET) %-30s " $(CURRENT) $(TOTAL) $(notdir $<)
	if $(CC) $(CFLAGS) -c $< -o $@ 2>/dev/null; then \
		echo "$(GREEN)вң“$(RESET)"; \
	else \
		echo "$(RED)вң—$(RESET)"; \
		$(CC) $(CFLAGS) -c $< -o $@; \
	fi

$(OBJ_DIR):
	printf "$(CYAN)CrГ©ation du rГ©pertoire $(OBJ_DIR)...$(RESET) "
	if mkdir -p $(OBJ_DIR) 2>/dev/null; then \
		echo "$(GREEN)вң“$(RESET)"; \
	else \
		echo "$(RED)вң—$(RESET)"; \
		mkdir -p $(OBJ_DIR); \
	fi

bonus: re

clean:
	printf "$(CYAN)Suppression de $(OBJ_DIR)...$(RESET) "
	if [ -d "$(OBJ_DIR)" ]; then \
		$(RM) -rf $(OBJ_DIR) && \
		echo "$(GREEN)вң“ Fichiers objets supprimГ©s$(RESET)"; \
	else \
		echo "$(YELLOW)вҡ  Rien Г  nettoyer$(RESET)"; \
	fi

fclean: clean
	printf "$(CYAN)Suppression de $(NAME)...$(RESET) "
	if rm $(NAME) 2>/dev/null; then \
		echo "$(GREEN)вң“$(RESET)"; \
	else \
		echo "$(YELLOW)вҡ  DГ©jГ  supprimГ©e$(RESET)"; \
	fi



add:
	echo "$(CYAN)--- Status avant ajout ---$(RESET)"
	git status -s
	git add .
	echo "$(GREEN)вң” Fichiers ajoutГ©s.$(RESET)"

_commit: add
	if [ -z "$(M)" ]; then \
		echo "\033[0;31mError: Le message du commit (M) est vide !\033[0m"; \
		exit 1; \
	fi
	git commit -m "$(TYPE): $(M)"
	git push
	echo "$(GREEN)рҹҡҖ Push terminГ© avec succГЁs ($(TYPE)).$(RESET)"

push_feat:
	$(MAKE) _commit TYPE=feat M="$(M)"

push_fix:
	$(MAKE) _commit TYPE=fix M="$(M)"

push_refactor:
	$(MAKE) _commit TYPE=refactor M="$(M)"

push_docs:
	$(MAKE) _commit TYPE=docs M="$(M)"

push_style:
	$(MAKE) _commit TYPE=style M="$(M)"

push_chore:
	$(MAKE) _commit TYPE=chore M="$(M)"

st:
	@git status


re: fclean all

run:
	./codexion 10 10000 2000 1000 2000 20 4000 fifo

run_hell:
	valgrind --tool=helgrind ./codexion 10 10000 2000 1000 2000 20 4000 fifo

run_leak:
	valgrind --leak-check=full ./codexion 10 10000 2000 1000 2000 20 4000 fifo

.PHONY: clean fclean re bonus \
		 push_chore push_doc \
		 push_facto push_feat \
		 push_fix push_style \
		 run_hell run_leak \
		 add st